# 前端开发环境 Dockerfile（支持热重载）
FROM node:20-alpine

WORKDIR /app

# 配置国内 npm 源
RUN npm config set registry https://registry.npmmirror.com

# 复制依赖文件
COPY package.json package-lock.json ./

# 安装依赖
RUN npm ci

# 复制源代码
COPY . .

# 暴露开发服务器端口（与 docker-compose.dev.yml 一致）
EXPOSE 5173

# 启动开发服务器（允许外部访问，端口 5173）
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
