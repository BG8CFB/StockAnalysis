{
  "enabledPlugins": {
    "glm-plan-usage@zai-coding-plugins": true,
    "glm-plan-bug@zai-coding-plugins": true
  },
  "alwaysThinkingEnabled": true,
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Skill",
      "mcp__*"
    ],
    "deny": [],
    "ask": [
      "Bash(git rm:*)",
      "Bash(docker system prune:*)",
      "Bash(del:*)",
      "Bash(rmdir:*)",
      "Bash(rm:*)",
      "Bash(Remove-Item:*)",
      "Bash(rd:*)",
      "Bash(erase:*)"
    ]
  }
}
